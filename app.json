{
  "expo": {
     "name": "AuraGifts",
    "slug": "asmr-gift-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
   "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#181229"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
   "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to let you take a photo of your gift for your order review."
      }
    },
    "android": {
      "package": "com.saumya.asmrgiftapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#181229"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "03b001f1-415c-4ce1-bc5a-00a007a43fb6"
      }
    }
  }
}
